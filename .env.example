# ShadowGate Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack Webhook (get from https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# UiPath Automation Cloud (get after UiPath Labs access approved)
UIPATH_CLIENT_ID=your_uipath_client_id_here
UIPATH_CLIENT_SECRET=your_uipath_client_secret_here
UIPATH_TENANT_NAME=your_tenant_name_here
UIPATH_ACCOUNT_NAME=your_account_name_here

# ShadowGate Config
SHADOWGATE_ENV=development
SHADOWGATE_LOG_LEVEL=INFO
SHADOWGATE_DB_PATH=shadowgate.db
APPROVAL_SERVER_URL=http://localhost:5000